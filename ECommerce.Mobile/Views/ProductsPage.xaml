<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="ECommerce.Mobile.Views.ProductsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ECommerce.Mobile.Views"
             Title="Produits">

    <!-- Plus de ScrollView, le CollectionView gère tout -->
    <CollectionView x:Name="ProductsCollectionView" Margin="10">

        <!-- Les boutons passent dans le Header -->
        <CollectionView.Header>
            <HorizontalStackLayout Spacing="10" Padding="10">
                <Button x:Name="RefreshButton"
                        Text="Recharger"
                        SemanticProperties.HeadingLevel="Level1"
                        Clicked="OnRefreshClicked" />
                <Button x:Name="AdminButton"
                        Text="Administration"
                        TextColor="White"
                        CornerRadius="8"
                        IsVisible="false"
                        Clicked="OnAdminTapped"/>
            </HorizontalStackLayout>
        </CollectionView.Header>

        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical"
                             Span="2"
                             HorizontalItemSpacing="10"
                             VerticalItemSpacing="10" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border Stroke="LightGray"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 10"
                        HorizontalOptions="Fill"
                        Padding="10"
                        Margin="2">
                    <VerticalStackLayout Spacing="8"
                                         HeightRequest="350"
                                         HorizontalOptions="Fill">

                        <Image HeightRequest="180"
                               Aspect="AspectFill"
                               BackgroundColor="AliceBlue"
                               WidthRequest="180"
                               Source="{Binding ImageUrl}" />

                        <Label Text="{Binding Name}"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="IndianRed"
                               HorizontalOptions="Fill"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding Description}"
                               FontSize="12"
                               TextColor="Gray"
                               MaxLines="2"
                               HorizontalOptions="Fill"
                               LineBreakMode="TailTruncation" />

                        <Label Text="{Binding Price, StringFormat='{0} €'}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="Gray"
                               HorizontalOptions="End" />
                        <Button Text="Voir le produit"
                                BackgroundColor="IndianRed"
                                TextColor="White"
                                CornerRadius="8"
                                CommandParameter="{Binding .}"
                                Clicked="OnProductTapped" />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>

    </CollectionView>
</ContentPage>
